generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  username      String         @unique @db.VarChar(255)
  email         String         @unique @db.VarChar(255)
  password_hash String         @db.VarChar(255)
  role          Role           @default(USER)
  created_at    DateTime       @default(now())
  answers       Answer[]
  acted_upon    Notification[] @relation("ActorNotifications")
  notifications Notification[] @relation("UserNotifications")
  questions     Question[]
  votes         Vote[]

  @@index([username])
  @@index([email])
}

model Question {
  id                 String        @id @default(uuid())
  title              String        @db.VarChar(255)
  description        String
  accepted_answer_id String?
  created_at         DateTime      @default(now())
  deleted_at         DateTime?
  author_id          String
  answers            Answer[]
  author             User          @relation(fields: [author_id], references: [id], onDelete: Cascade)
  tags               QuestionTag[]

  @@index([created_at])
}

model Answer {
  id          String    @id @default(uuid())
  body        String
  score       Int       @default(0)
  created_at  DateTime  @default(now())
  deleted_at  DateTime?
  question_id String
  author_id   String
  author      User      @relation(fields: [author_id], references: [id], onDelete: Cascade)
  question    Question  @relation(fields: [question_id], references: [id], onDelete: Cascade)
  votes       Vote[]

  @@index([question_id])
  @@index([score])
}

model Tag {
  id        String        @id @default(uuid())
  name      String        @unique @db.VarChar(255)
  questions QuestionTag[]

  @@index([name])
}

model QuestionTag {
  question_id String
  tag_id      String
  question    Question @relation(fields: [question_id], references: [id], onDelete: Cascade)
  tag         Tag      @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@id([question_id, tag_id])
  @@index([tag_id])
}

model Vote {
  user_id   String
  answer_id String
  value     Int    @db.SmallInt
  answer    Answer @relation(fields: [answer_id], references: [id], onDelete: Cascade)
  user      User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([user_id, answer_id])
}

model Notification {
  id           String           @id @default(uuid())
  type         NotificationType
  reference_id String
  is_read      Boolean          @default(false)
  created_at   DateTime         @default(now())
  user_id      String
  actor_id     String
  actor        User             @relation("ActorNotifications", fields: [actor_id], references: [id], onDelete: Cascade)
  user         User             @relation("UserNotifications", fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, is_read])
}

enum Role {
  GUEST
  USER
  ADMIN
}

enum NotificationType {
  ANSWER
  MENTION
  SYSTEM
}
